# Stress: Triple-nested loops with variables at each level.
# Tests scope cleanup and frame arena reset at each loop boundary.
# 50 * 50 * 50 = 125,000 iterations.

make total get 0
make i get 0
jasi (i small pass 50) start
    make j get 0
    jasi (j small pass 50) start
        make k get 0
        jasi (k small pass 50) start
            total get total add 1
            k get k add 1
        end
        j get j add 1
    end
    i get i add 1
end
shout(total)
