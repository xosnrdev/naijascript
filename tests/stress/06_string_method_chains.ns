# Stress: String method chains in a loop.
# Each iteration creates temporaries from method calls.
# Frame arena should reclaim all temporaries per iteration.

make i get 0
make count get 0
jasi (i small pass 5000) start
    make base get "  Hello World  "
    make trimmed get base.trim()
    make upper get trimmed.to_uppercase()
    make lower get upper.to_lowercase()
    make found get lower.find("world")
    if to say (found pass 0 minus 1) start
        count get count add 1
    end
    make replaced get lower.replace("world", "naija")
    make sliced get replaced.slice(0, 5)
    i get i add 1
end
shout(count)
